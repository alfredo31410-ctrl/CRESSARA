# Copy this file to backend/.env for local development.
# In production, set the same variables directly in your hosting provider.

ENVIRONMENT=development
MONGO_URL=mongodb://localhost:27017
DB_NAME=cressara
MONGO_TIMEOUT_MS=5000
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@cresara.com
ADMIN_PASSWORD=replace-with-a-strong-password
CORS_ORIGINS=http://localhost:3010,http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
